# Cuboid Platform — Environment Configuration
# Copy this file to .env.local and fill in your values

# ================================================
# DATABASE
# ================================================
# PostgreSQL connection string
# Required for production and local development with live DB
# Leave empty or comment out to enable MOCK MODE
DATABASE_URL="postgresql://user:password@localhost:5432/cuboid?schema=public"

# Force mock mode even when DATABASE_URL is set
# Useful for: UI verification, dashboard walkthroughs, investor demos, staging without infra
CUBOID_FORCE_MOCK="false"

# ================================================
# AUTHENTICATION
# ================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# ================================================
# SUPABASE (Realtime)
# ================================================
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ================================================
# STRIPE (Payments)
# ================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ================================================
# WHATSAPP (Twilio)
# ================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ================================================
# API KEYS
# ================================================
CUBOID_API_KEY=""

# ================================================
# MOCK MODE DOCUMENTATION
# ================================================
# When DATABASE_URL is empty OR CUBOID_FORCE_MOCK=true:
# - All API routes return deterministic mock data
# - Market ticker shows realistic Nigerian FX rates
# - Dashboards display believable placeholder data
# - No database connection required
# 
# Mock mode exists ONLY for:
# - UI verification
# - Dashboard walkthroughs
# - Investor demos
# - Staging environments without full infrastructure
# 
# NEVER use mock mode in production with real customer data.
