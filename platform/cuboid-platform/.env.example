# CUBOID Platform Environment Variables
# Copy to .env and fill in values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/cuboid
DATABASE_POOL_SIZE=20
DATABASE_SSL=true

# ===========================================
# AUTH
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
SESSION_EXPIRY_DAYS=30

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# API & APPS
# ===========================================
API_URL=https://api.cuboid.io
WEB_APP_URL=https://app.cuboid.io
ADMIN_URL=https://admin.cuboid.io
PARTNER_URL=https://partner.cuboid.io
REGULATOR_URL=https://regulator.cuboid.io

# ===========================================
# PARTNERS
# ===========================================
PARTNER_BANK_1_URL=https://partner-bank-1.api
PARTNER_BANK_1_KEY=partner-key
PARTNER_IMTO_1_URL=https://partner-imto-1.api
PARTNER_IMTO_1_KEY=partner-key

# ===========================================
# NOTIFICATIONS
# ===========================================
SENDGRID_API_KEY=your-sendgrid-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
WHATSAPP_TOKEN=your-whatsapp-token

# ===========================================
# STORAGE
# ===========================================
S3_BUCKET=cuboid-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ===========================================
# OBSERVABILITY
# ===========================================
DATADOG_API_KEY=your-datadog-key
DATADOG_SITE=us
SENTRY_DSN=your-sentry-dsn

# ===========================================
# FEATURES
# ===========================================
FEATURE_ESCROW=true
FEATURE_FX=true
FEATURE_MOBILE=true