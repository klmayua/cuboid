// ============================================================
// WHATSAPP ORCHESTRATION
// ============================================================

enum WhatsAppIdentityStatus {
  UNVERIFIED
  VERIFIED
  SUSPENDED
}

model WhatsAppIdentity {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?                @map("user_id") @db.Uuid
  phone       String                 @unique
  countryCode String                 @default("+234") @map("country_code")
  verified    Boolean                @default(false)
  optedIn     Boolean                @default(true)
  language    String                 @default("en") @db.VarChar(5)
  timezone    String                 @default("Africa/Lagos") @map("timezone")
  lastSeenAt  DateTime?              @map("last_seen_at") @db.Timestamptz(6)
  trustScore  Int                    @default(50)
  status      WhatsAppIdentityStatus @default(UNVERIFIED)
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  user           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversations  WhatsAppConversation[]
  Organization   Organization?          @relation(fields: [organizationId], references: [id])
  organizationId String?                @db.Uuid

  @@index([phone])
  @@index([userId])
  @@index([status])
  @@map("whatsapp_identities")
}

enum ConversationState {
  PENDING
  ACTIVE
  ASSIGNED
  COMPLETED
  ABANDONED
}

enum ConversationChannel {
  INBOUND
  OUTBOUND
}

model WhatsAppConversation {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whatsappId     String              @map("whatsapp_id") @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  state          ConversationState   @default(PENDING)
  channel        ConversationChannel @default(INBOUND)
  assignedTo     String?             @map("assigned_to") @db.Uuid
  workflow       String?             @db.VarChar(100)
  context        Json?               @db.JsonB
  lastMessageAt  DateTime?           @map("last_message_at") @db.Timestamptz(6)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  whatsapp     WhatsAppIdentity  @relation(fields: [whatsappId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?             @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  messages     WhatsAppMessage[]

  @@index([whatsappId])
  @@index([organizationId])
  @@index([state])
  @@index([workflow])
  @@map("whatsapp_conversations")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  INTERACTIVE
  BUTTONS
  LIST
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model WhatsAppMessage {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  messageId      String?          @unique @map("message_id") @db.Uuid
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  body           String           @db.Text
  payload        Json?            @db.JsonB
  status         MessageStatus    @default(QUEUED)
  mediaUrl       String?          @map("media_url") @db.Uuid
  deliveredAt    DateTime?        @map("delivered_at") @db.Timestamptz(6)
  readAt         DateTime?        @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

enum WorkflowState {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRY
}

model WorkflowJob {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  workflow       String        @db.VarChar(100)
  subjectType    String        @map("subject_type") @db.VarChar(50)
  subjectId      String        @map("subject_id") @db.Uuid
  state          WorkflowState @default(PENDING)
  attempts       Int           @default(0)
  maxAttempts    Int           @default(3)
  error          String?       @db.Text
  nextRetryAt    DateTime?     @map("next_retry_at") @db.Timestamptz(6)
  startedAt      DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  User         User?        @relation(fields: [userId], references: [id])
  userId       String?      @db.Uuid

  @@index([organizationId])
  @@index([workflow, state])
  @@index([subjectType, subjectId])
  @@map("workflow_jobs")
}

model WhatsAppTemplate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(100)
  content        String   @db.Text
  category       String   @default("TRANSACTIONAL") @db.VarChar(50)
  variables      Json?    @db.JsonB
  approved       Boolean  @default(false)
  metaTemplateId String?  @map("meta_template_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  User         User?        @relation(fields: [userId], references: [id])
  userId       String?      @db.Uuid

  @@index([organizationId])
  @@index([name])
  @@map("whatsapp_templates")
}

